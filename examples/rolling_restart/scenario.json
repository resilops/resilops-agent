{
    "id": 4,
    "scenario_id": 4,
    "name": "rolling_restart",
    "title": "Can the workload complete a rolling restart?",
    "description": "Restart the workload and verify new pods start with the current image, configuration, secrets, and dependencies while availability is maintained.",
    "template": {
        "namespace": "nginx",
        "workload": "nginx-deployment"
    },
    "steps": [
        {
            "type": "guardrail",
            "name": "ensure_workload_steady",
            "params": {}
        },
        {
            "type": "guardrail",
            "name": "ensure_minimum_replicas_for_restart",
            "params": {}
        },
        {
            "type": "guardrail",
            "name": "ensure_hpa_not_at_max_replicas",
            "params": {}
        },
        {
            "type": "action",
            "name": "perform_rolling_restart",
            "params": {}
        },
        {
            "type": "rollback",
            "name": "wait_until_rolling_restart_complete",
            "params": {
                "timeout_seconds": 600
            }
        }
    ],
    "observer": {
        "name": "measure_endpoint_latency",
        "config": {
            "sampling_interval_seconds": 4,
            "warmup_period_seconds": 10,
            "grace_period_seconds": 10
        },
        "params": {
            "endpoint": "http://nginx-service.nginx.svc.cluster.local:80/",
            "requests_per_interval": 3,
            "request_timeout_seconds": 5
        }
    }
}
