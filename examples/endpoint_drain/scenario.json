{
    "id": 5,
    "scenario_id": 5,
    "name": "endpoint_drain",
    "title": "Can one pod be drained from Service traffic?",
    "description": "Remove one Ready pod from Service endpoints without restarting or replacing it, and verify traffic continues through the remaining Ready endpoints.",
    "template": {
        "namespace": "nginx",
        "workload": "nginx-deployment",
        "service_name": "nginx-service"
    },
    "steps": [
        {
            "type": "guardrail",
            "name": "ensure_workload_steady",
            "params": {}
        },
        {
            "type": "guardrail",
            "name": "ensure_hpa_not_at_max_replicas",
            "params": {}
        },
        {
            "type": "guardrail",
            "name": "ensure_minimum_replicas",
            "params": {}
        },
        {
            "type": "guardrail",
            "name": "ensure_pdb_not_violated",
            "params": {}
        },
        {
            "type": "action",
            "name": "drain_pod_from_service_endpoints",
            "params": {
                "timeout_seconds": 120
            }
        },
        {
            "type": "rollback",
            "name": "restore_pod_to_service_endpoints",
            "params": {
                "timeout_seconds": 120
            }
        }
    ],
    "observer": {
        "name": "measure_endpoint_latency",
        "config": {
            "sampling_interval_seconds": 4,
            "warmup_period_seconds": 10,
            "grace_period_seconds": 10
        },
        "params": {
            "endpoint": "http://nginx-service.nginx.svc.cluster.local:80/",
            "requests_per_interval": 3,
            "request_timeout_seconds": 5
        }
    }
}
