{
    "suite": {
        "id": 1,
        "run_id": 2,
        "title": "Resiliency Suite 1",
        "tags": ["kubernetes"],
        "execution": {
            "mode": "series",
            "stop_on_failure": "true"
        },
        "scenarios": [1]
    },
    "scenarios": [
        {
            "id": 1,
            "suite_id": 1,
            "title": "Do the application scale according to the customer needs?",
            "description": "We expect HPA is configured and kubernetes pods scale within a timeframe.",
            "template": {
                "namespace": "nginx",
                "workload": "nginx-deployment",
                "container_name": "nginx",
                "metric_source": "Resource",
                "resource_type": "cpu",
                "idle_cpu_pct": 10,
                "min_pods_idle_pct": 0,
                "pod_cpu_stress_threshold_pct": 95,
                "max_stress_duration_seconds": 300,
                "hpa_scale_down_timeout_seconds": 700
            },
            "steps": [
                {
                    "type": "guardrail",
                    "name": "validate_hpa_cpu_scaling_guardrail",
                    "overrides": {}
                },
                {
                    "type": "action",
                    "name": "stress_cpu_hpa",
                    "overrides": {}
                },
                {
                    "type": "rollback",
                    "name": "wait_until_hpa_scales_down",
                    "overrides": {}
                }
            ],
            "observer": {
                "name": "measure_endpoint_latency",
                "config": {
                    "sampling_interval_seconds": 5,
                    "warmup_period_seconds": 5,
                    "grace_period_seconds": 5
                },
                "kwargs": {
                    "endpoint": "http://nginx-service.nginx.svc.cluster.local:80/",
                    "namespace": "nginx",
                    "workload": "nginx-deployment",
                    "requests_per_interval": 3,
                    "http_request_timeout_seconds": 5
                }
            }
        }
    ]
}
