{
    "suite": {
        "id": 1,
        "run_id": 2,
        "title": "Resiliency Suite 1",
        "tags": ["kubernetes"],
        "execution": {
            "mode": "series",
            "stop_on_failure": "true"
        },
        "scenarios": [1]
    },
    "scenarios": [
        {
            "id": 1,
            "suite_id": 1,
            "title": "Do the application scale according to the customer needs?",
            "description": "We expect HPA is configured and kubernetes pods scale within a timeframe.",
            "template": {
                "namespace": "nginx",
                "workload": "nginx-deployment",
                "container_name": "nginx",
                "metric_type": "Resource",
                "resource": "cpu",
                "idle_cpu_pct": 10,
                "min_pods_idle_pct": 0,
                "max_cpu_stress_pct_per_pod": 95,
                "max_stress_duration": 300,
                "wait_for_stability": 10
            },
            "steps": [
                {
                    "type": "guardrail",
                    "name": "validate_hpa_cpu_scaling_guardrail",
                    "overrides": {}
                },
                {
                    "type": "action",
                    "name": "stress_cpu_hpa",
                    "overrides": {}
                },
                {
                    "type": "rollback",
                    "name": "wait_for_workload_stability",
                    "overrides": {}
                }
            ],
            "observer": {
                "name": "measure_endpoint_latency",
                "config": {
                    "sampling_interval": 5,
                    "warmup_period": 5,
                    "grace_period": 5
                },
                "kwargs": {
                    "endpoint": "http://nginx-service.nginx.svc.cluster.local:80/",
                    "namespace": "nginx",
                    "workload": "nginx-deployment",
                    "requests_per_interval": 3,
                    "timeout": 5
                }
            }
        }
    ]
}
