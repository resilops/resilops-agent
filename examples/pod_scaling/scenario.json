{
    "suite": {
        "id": 1,
        "run_id": 2,
        "title": "Resiliency Suite 1",
        "tags": ["kubernetes"],
        "execution": {
            "mode": "series",
            "stop_on_failure": "true"
        },
        "scenarios": [1]
    },
    "scenarios": [
        {
            "id": 1,
            "suite_id": 1,
            "name": "HPA_SCALE_ON_CPU_STRESS",
            "title": "Do the application scale according to the customer needs?",
            "description": "We expect HPA is configured and kubernetes pods scale within a timeframe.",
            "template": {
                "namespace": "nginx",
                "workload": "nginx-deployment",
                "container_name": "nginx",
                "metric_source": "Resource",
                "resource_type": "cpu",
                "idle_cpu_pct": 10,
                "min_idle_pct": 0,
                "cpu_stress_threshold_pct": 95
            },
            "steps": [
                {
                    "type": "guardrail",
                    "name": "validate_metric_and_resource",
                    "kwargs": {}
                },
                {
                    "type": "guardrail",
                    "name": "ensure_hpa_exists",
                    "kwargs": {}
                },
                {
                    "type": "guardrail",
                    "name": "validate_hpa_resource_metric",
                    "kwargs": {}
                },
                {
                    "type": "guardrail",
                    "name": "validate_pods_to_stress_cpu",
                    "kwargs": {}
                },
                {
                    "type": "guardrail",
                    "name": "ensure_hpa_not_at_max_replicas",
                    "kwargs": {}
                },
                {
                    "type": "guardrail",
                    "name": "ensure_metrics_server_available",
                    "kwargs": {}
                },
                {
                    "type": "action",
                    "name": "stress_cpu_hpa",
                    "kwargs": {
                        "max_stress_duration_seconds": 300
                    }
                },
                {
                    "type": "rollback",
                    "name": "wait_until_hpa_scales_down",
                    "kwargs": {
                        "timeout_seconds": 900
                    }
                }
            ],
            "observer": {
                "name": "measure_endpoint_latency",
                "config": {
                    "sampling_interval_seconds": 5,
                    "warmup_period_seconds": 5,
                    "grace_period_seconds": 5
                },
                "kwargs": {
                    "endpoint": "http://nginx-service.nginx.svc.cluster.local:80/",
                    "namespace": "nginx",
                    "workload": "nginx-deployment",
                    "requests_per_interval": 3,
                    "request_timeout_seconds": 5
                }
            }
        }
    ]
}
